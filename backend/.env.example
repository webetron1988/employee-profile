# Environment Configuration
CI_ENVIRONMENT = development

# Database Configuration
database.default.hostname = localhost
database.default.database = employee_profile_db
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port = 3306

# HRMS Integration - SSO Configuration
hrms.sso_endpoint = https://hrms.company.com/api/sso/login
hrms.api_base_url = https://hrms.company.com/api
hrms.jwt_secret_key = your_jwt_secret_key_here
hrms.jwt_algorithm = RS256
hrms.token_expiry = 3600

# Encryption Configuration
encryption.key = your_encryption_key_here
encryption.algorithm = AES-256-CBC

# AWS S3 Configuration
aws.s3.key = your_s3_key
aws.s3.secret = your_s3_secret
aws.s3.region = us-east-1
aws.s3.bucket = employee-profile-bucket

# Redis Configuration (Cache & Session)
redis.host = localhost
redis.port = 6379
redis.password = 
redis.database = 0

# Application
app.baseURL = http://localhost:8000
app.indexPage = 
app.uriProtocol = REQUEST_URI

# Security
security.sessionDriver = RedisHandler
security.cookieHttponly = true
security.cookieSecure = false

# Logging
logging.threshold = 4
