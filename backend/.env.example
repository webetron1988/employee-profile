# ============================================================
# Employee Profile System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ============================================================

CI_ENVIRONMENT = production

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
app.baseURL    = https://yourdomain.com/api
app.indexPage  =
app.uriProtocol = REQUEST_URI

# ------------------------------------------------------------
# Database (Employee Profile)
# ------------------------------------------------------------
database.default.hostname = localhost
database.default.database = employee_profile_db
database.default.username = ep_user
database.default.password = CHANGE_ME
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

# ------------------------------------------------------------
# HRMS Database (read-only access to sync employee/user data)
# ------------------------------------------------------------
database.hrms.hostname = localhost
database.hrms.database = hrms-extension-v2
database.hrms.username = ep_user
database.hrms.password = CHANGE_ME
database.hrms.DBDriver = MySQLi
database.hrms.DBPrefix =
database.hrms.port     = 3306
database.hrms.charset  = utf8mb4
database.hrms.DBCollat = utf8mb4_general_ci

# ------------------------------------------------------------
# Encryption (CHANGE — must be exactly 32 characters)
# ------------------------------------------------------------
encryption.key       = GENERATE_A_RANDOM_32_CHAR_KEY!!
encryption.algorithm = AES-256-CBC

# ------------------------------------------------------------
# JWT Keys
# Place RSA PEM files in backend/config/keys/ directory
# ------------------------------------------------------------
jwt.algorithm = RS256

# ------------------------------------------------------------
# HRMS Integration
# ------------------------------------------------------------
hrms.sso_endpoint   = https://yourdomain.com/hrms_extension_v2/ep-profile
hrms.base_url       = https://yourdomain.com/hrms_extension_v2
hrms.api_base_url   = https://yourdomain.com/hrms_extension_v2
hrms.jwt_secret_key = SAME_KEY_AS_HRMS_SYSTEM
hrms.jwt_algorithm  = HS256
hrms.token_expiry   = 120

# ------------------------------------------------------------
# Service-to-Service API Key
# ------------------------------------------------------------
EP_API_KEY = GENERATE_A_UNIQUE_API_KEY

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
security.sessionDriver  = FileHandler
security.cookieHttponly = true
security.cookieSecure   = true

# ------------------------------------------------------------
# Logging (1=ERROR, 4=INFO, 8=DEBUG)
# ------------------------------------------------------------
logging.threshold = 1
