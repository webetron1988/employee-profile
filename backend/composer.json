{
  "name": "webetron/employee-profile-backend",
  "description": "Employee Profile System - Backend (CodeIgniter 4)",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": ["codeigniter4", "hrms", "employee", "profile"],
  "require": {
    "php": "^8.2",
    "codeigniter4/framework": "^4.4",
    "firebase/php-jwt": "^6.8",
    "aws/aws-sdk-php": "^3.265",
    "predis/predis": "^2.1",
    "guzzlehttp/guzzle": "^7.5",
    "doctrine/orm": "^2.14"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.9",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "scripts": {
    "start": "php spark serve",
    "test": "phpunit",
    "lint": "phpstan analyse app/",
    "migrate": "php spark migrate",
    "seed": "php spark db:seed"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "config/"
    }
  }
}
