<!--begin::Profile Banner-->
<div class="card card-custom gutter-b shadow-v2 rounded-lg">
  <div class="card-body p-5">
    <div class="d-flex align-items-center">
      <!--begin::Avatar-->
      <div class="symbol symbol-60 symbol-xxl-100 mr-5 align-self-start align-self-xxl-center">
        <div class="symbol-label" style="background-image:url('{{employee.avatar}}')"></div>
        <i class="symbol-badge bg-success"></i>
      </div>
      <!--end::Avatar-->
      <!--begin::Info-->
      <div class="d-flex flex-column">
        <div class="d-flex align-items-center mb-2">
          <h4 class="text-black font-weight-bolder mb-0">{{employee.fullName}}</h4>
          <span class="label label-sm label-light-success label-inline ml-3">{{employee.status}}</span>
        </div>
        <span class="text-muted font-weight-bold">{{employee.jobTitle}}</span>
        <span class="text-muted font-size-sm">{{employee.department}}</span>
        <span class="text-muted font-size-sm">{{employee.employeeId}}</span>
      </div>
      <!--end::Info-->
    </div>
  </div>
</div>
<!--end::Profile Banner-->
